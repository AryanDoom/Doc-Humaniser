{
  "manifest_version": 3,
  "name": "Doc Humanizer",
  "version": "1.1",
  "permissions": ["activeTab", "scripting"],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
